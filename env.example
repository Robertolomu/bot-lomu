# ─── Bot LOMU — Variables de entorno ───────────────────────────
# Copia este archivo como .env y llena los valores
# NUNCA subas el .env a GitHub

# Tu API Key de Anthropic (claude.ai → Configuración → API Keys)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# URL donde corre WAHA (en Railway te lo da automático)
WAHA_URL=https://TU-WAHA.up.railway.app

# Nombre de la sesión en WAHA (deja "default" si es una sola)
WAHA_SESSION=default

# URL CSV del Google Sheet (ya configurada, no tocar)
CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vThPXYqYxXVdzAwhtqIfACyyOghZ_e4O4YE_m5jaE1Zn5TxiyBUp6Q8WL8FOy-XeKigTHFDFd_ZdYR/pub?gid=2044008320&single=true&output=csv

# Puerto (Railway lo asigna solo)
PORT=8080
